def isNumbers(number):
    isInteger = True    

    for eachCharacter in number:
        if (eachCharacter >= '0' and eachCharacter <= '9'):
            continue
        else:
            isInteger = False
            break
    
    return isInteger
        
def isNumbers_V2(number):
